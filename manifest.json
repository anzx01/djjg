{
  "manifest_version": 3,
  "version": "0.1.0",
  "name": "内容解构演示 - UI 原型",
  "description": "演示性界面原型，仅在扩展弹窗内展示预设的示例报告；不读取、不上传、不访问任何网站内容。",

  "permissions": [
    "storage"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "内容解构演示 - UI 原型",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
